2024-06-24 13:39:05,317 [system.py:update_program()] - program: {'channel': 'dev', 'debug_enabled': False, 'channel_invalid': False, 'is_valid': True, 'configured_type': 'git_repo', 'info_tags': [], 'detected_type': 'git_repo', 'remote_alias': 'origin', 'branch': 'master', 'owner': 'Klipper3d', 'repo_name': 'klipper', 'remote_url': 'https://github.com/Klipper3d/klipper', 'recovery_url': 'https://github.com/Klipper3d/klipper', 'version': 'v0.12.0-230', 'remote_version': 'v0.12.0-249', 'rollback_version': 'v0.12.0-207', 'current_hash': '0d87bec159eba63744d820b5beaef5da20388ba4', 'remote_hash': 'a19d64febdbaa7d5ec0a0912bb65c6547c370ec3', 'is_dirty': False, 'detached': False, 'commits_behind': [{'sha': 'a19d64febdbaa7d5ec0a0912bb65c6547c370ec3', 'author': 'Eric Callahan', 'date': '1718819252', 'subject': 'docs: add rapid probing documentation', 'message': 'Signed-off-by:  Eric Callahan <arksine.code@gmail.com>', 'tag': None}, {'sha': 'a19af088945fdd33e49477413b90ee061c716e71', 'author': 'Eric Callahan', 'date': '1718819252', 'subject': 'bed_mesh: add support for MESH_PPS param in BMC', 'message': 'In addition, do not respond with generated points.\n\nSigned-off-by:  Eric Callahan <arksine.code@gmail.com>', 'tag': None}, {'sha': '2c7e09cfa6379e94fcc78774f186bce0bf0a2078', 'author': 'Eric Callahan', 'date': '1718819252', 'subject': 'bed_mesh: use generated XY positions in probe_finalize()', 'message': 'The scan modes provide kinematic XYZ coordinates in the\nprobe results.  These positions may deviate from the requested\npositions, which can introduce errors in mesh generation when\ntransposing the result into the Z matrix.\n\nRely on the coordinates generated by bed mesh to transpose\nthe matrix, presuming that points at the same index in the\nlist match.\n\nSigned-off-by:  Eric Callahan <arksine.code@gmail.com>', 'tag': None}, {'sha': 'fc0f17b920ce0fd2dca90dce0bd7df4573aee568', 'author': 'Eric Callahan', 'date': '1718819252', 'subject': 'graph_mesh: script for mesh visualization and analysis', 'message': 'Signed-off-by:  Eric Callahan <arksine.code@gmail.com>', 'tag': None}, {'sha': 'c7b7c11cc323e7e28521259e615f674990a1701e', 'author': 'Eric Callahan', 'date': '1718819252', 'subject': 'bed_mesh:  add dump_mesh webhooks API', 'message': 'Returns current mesh configuration and state.  Includes probed and\nmesh matrices, saved profiles, current points, and travel paths.\n\nSigned-off-by:  Eric Callahan <arksine.code@gmail.com>', 'tag': None}, {'sha': 'f2df011c68aeff1c9240613837f91f04baa8da83', 'author': 'Eric Callahan', 'date': '1718819252', 'subject': 'bed_mesh: optimize rapid travel paths', 'message': 'This adds supplemental path generation that implements\n"overshoot" when a change of direction is performed\nduring a rapid scan.  This overshoot reduces measurement\nerror at the extremes of the mesh along the X axis.\n\nSigned-off-by:  Eric Callahan <arksine.code@gmail.com>', 'tag': None}, {'sha': '0a14e3315084065b19163104c3604d13a7c2dbc8', 'author': "Kevin O'Connor", 'date': '1718819252', 'subject': 'probe_eddy_current: Add support for "rapid_scan" mode', 'message': "Add a scanning mode that does not require pausing the toolhead at each\nprobe point.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': '11f04ba1bae774d32fd43bed4a0772c58d8df199', 'author': "Kevin O'Connor", 'date': '1718646545', 'subject': 'configfile: Allow getchoice() to take a list', 'message': "If a list is passed to getchoice(), seamlessly convert it to a dict.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': '863a463cb2d07fce2ae09e2b0f925bdf201051dc', 'author': "Kevin O'Connor", 'date': '1718642707', 'subject': 'rp2040_link: Explicitly set klipper.elf output section flags to avoid warning', 'message': 'Avoid pointless "LOAD segment with RWX permissions" linker warnings\nduring the rp2040 build.\n\nSigned-off-by: Kevin O\'Connor <kevin@koconnor.net>', 'tag': None}, {'sha': 'ae227d485cdac859b22d77da4072f870bce07740', 'author': "Kevin O'Connor", 'date': '1718642707', 'subject': 'armcm_link: Fix build on recent arm gcc/newlibc versions', 'message': 'It seems recent arm gcc versions no longer build correctly using the\n"--specs=nano.specs --specs=nosys.specs" linker flags.  Replace those\nlinker flags with "-nostdlib -lgcc -lc_nano".\n\nSigned-off-by: Kevin O\'Connor <kevin@koconnor.net>', 'tag': None}, {'sha': '433fcb6f249406c8b5e2f25d1e870809beeafb40', 'author': "Kevin O'Connor", 'date': '1718464016', 'subject': 'axis_twist_compensation: Fix missing probe import', 'message': "Fixes missing import introduced in commit bec47e04.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': 'beba2c2d3380acc966e876ee02e4902ab3e71976', 'author': "Kevin O'Connor", 'date': '1718463830', 'subject': 'axis_twist_compensation: No need to rename bed_mesh and manual_probe', 'message': "Signed-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': 'fcf064ba6851042a12a71975c229a9670b34cf31', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe_eddy_current: Add support for probing in "scan" mode', 'message': 'When probing in "scan" mode, the toolhead will pause at each position,\nbut does not descend.  This can notably reduce the total probing time.\n\nSigned-off-by: Kevin O\'Connor <kevin@koconnor.net>', 'tag': None}, {'sha': 'aa0dbf6ee652fe87b4fcc828482309c6830f0efb', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe_eddy_current: Calculate toolhead position along with probed position', 'message': "Support calculating the low-level kinematic toolhead position while\ncalculating the probed frequency.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': '49f511e6798bae55fd25df8662eb6d5234f17280', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe_eddy_current: Process samples as they arrive', 'message': "Convert samples into probe frequencies as the samples arrive.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': '429aa2b2a6d48246331af38929d358e265e0ef19', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe_eddy_current: Generate Z height from average frequency', 'message': "Calculate the average frequency from a set of samples, and then\ncalculate the estimated Z height from that frequency.  This may\nimprove accuracy, as the frequency to Z height is not linear and\naveraging after the non-linear transform could bias the results.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': 'bf1bc1ee0f8b9baac322ffaa00d54afb02c2bd52', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe_eddy_current: Introduce new EddyGatherSamples helper class', 'message': "Split the sample gathering code out of EddyEndstopWrapper class and\ninto a new EddyGatherSamples class.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': '1591a51f76cff336f0109bf4459bfa46dca1eaa3', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe: Gather multiple results in ProbeSessionHelper', 'message': "Change run_probe() to gather the results locally, and introduce a new\npull_probed_results() method that returns the previously probed\nresults.  This is in preparation for future probing code that benefits\nfrom batching probe results.\n\nSigned-off-by: Kevin O'Connor <kevin@koconnor.net>", 'tag': None}, {'sha': '8de7153952c7513adec9f35a8d05b9f8bd00710a', 'author': "Kevin O'Connor", 'date': '1718386687', 'subject': 'probe: Rework ProbePointsHelper to store results locally', 'message': 'Store the results of each probe attempt in a local "results" variable\n(instead of a class variable) when performing "automatic" probes.\nThis is in preparation for gathering the results in the probing\nimplementation.\n\nSigned-off-by: Kevin O\'Connor <kevin@koconnor.net>', 'tag': None}], 'commits_behind_count': 19, 'git_messages': [], 'full_version_string': 'v0.12.0-230-g0d87bec1', 'pristine': False, 'corrupt': False, 'warnings': [], 'anomalies': ["Repo has untracked source files: ['klippy/extras/gcode_shell_command.py']"]}
